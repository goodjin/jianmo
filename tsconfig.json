{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@extension/*": ["src/extension/*"],
      "@core/*": ["src/core/*"],
      "@editor/*": ["src/editor/*"],
      "@plugins/*": ["src/plugins/*"],
      "@image/*": ["src/image/*"],
      "@services/*": ["src/services/*"],
      "@types/*": ["src/types/*"]
    },
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "webview"]
}
