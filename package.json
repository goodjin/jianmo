{
  "name": "markly",
  "displayName": "Markly",
  "description": "A clean and intuitive WYSIWYG Markdown editor for VSCode",
  "version": "1.7.1",
  "publisher": "jianmo",
  "repository": {
    "type": "git",
    "url": "https://github.com/goodjin/jianmo.git"
  },
  "bugs": {
    "url": "https://github.com/goodjin/jianmo/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:markly.preview",
    "onLanguage:markdown"
  ],
  "main": "./dist/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "markly.toggleMode",
        "title": "Toggle Edit Mode",
        "icon": "$(refresh)"
      },
      {
        "command": "markly.export.pdf",
        "title": "Export as PDF",
        "icon": "$(file-pdf)"
      },
      {
        "command": "markly.export.html",
        "title": "Export as HTML",
        "icon": "$(file-code)"
      },
      {
        "command": "markly.export.image",
        "title": "Export as Image",
        "icon": "$(file-media)"
      },
      {
        "command": "markly.toggleOutline",
        "title": "Toggle Outline",
        "icon": "$(list-tree)"
      },
      {
        "command": "markly.find.toggle",
        "title": "Find: Toggle Find and Replace Panel",
        "icon": "$(search)"
      },
      {
        "command": "markly.find.next",
        "title": "Find: Next Match",
        "icon": "$(arrow-down)"
      },
      {
        "command": "markly.find.previous",
        "title": "Find: Previous Match",
        "icon": "$(arrow-up)"
      },
      {
        "command": "markly.edit.pastePlain",
        "title": "Edit: Paste as Plain Text",
        "icon": "$(clippy)"
      },
      {
        "command": "markly.edit.wrapUrlLink",
        "title": "Edit: Wrap Selection as Markdown Link (URL)",
        "icon": "$(link-external)"
      },
      {
        "command": "markly.insert.table",
        "title": "Insert Table",
        "icon": "$(table)"
      },
      {
        "command": "markly.insert.codeBlock",
        "title": "Insert Code Block",
        "icon": "$(code)"
      },
      {
        "command": "markly.insert.image",
        "title": "Insert Image",
        "icon": "$(file-media)"
      },
      {
        "command": "markly.insert.link",
        "title": "Insert Link",
        "icon": "$(link)"
      },
      {
        "command": "markly.insert.hr",
        "title": "Insert Horizontal Rule",
        "icon": "$(horizontal-rule)"
      },
      {
        "command": "markly.image.copyMissingRefs",
        "title": "Images: Copy Missing Image List",
        "icon": "$(copy)"
      },
      {
        "command": "markly.image.openAssetsDirectory",
        "title": "Images: Open Assets Directory",
        "icon": "$(folder-opened)"
      },
      {
        "command": "markly.image.repairFirstMissingRef",
        "title": "Images: Repair First Missing Image",
        "icon": "$(wrench)"
      },
      {
        "command": "markly.image.normalizeRefs",
        "title": "Images: Normalize Local Image Paths",
        "icon": "$(symbol-file)"
      },
      {
        "command": "markly.image.batchReplaceInDocument",
        "title": "Images: Batch Replace Text in Document",
        "icon": "$(replace-all)"
      },
      {
        "command": "markly.image.replaceMovedImageRef",
        "title": "Images: Replace Image Reference (Pick Old/New)",
        "icon": "$(files)"
      },
      {
        "command": "markly.table.addRowBefore",
        "title": "Table: Add Row Above",
        "icon": "$(insert)"
      },
      {
        "command": "markly.table.addRowAfter",
        "title": "Table: Add Row Below",
        "icon": "$(insert)"
      },
      {
        "command": "markly.table.addColBefore",
        "title": "Table: Add Column Left",
        "icon": "$(insert)"
      },
      {
        "command": "markly.table.addColAfter",
        "title": "Table: Add Column Right",
        "icon": "$(insert)"
      },
      {
        "command": "markly.table.toggleHeaderRow",
        "title": "Table: Toggle Header Row",
        "icon": "$(table)"
      },
      {
        "command": "markly.table.alignLeft",
        "title": "Table: Align Left",
        "icon": "$(align-left)"
      },
      {
        "command": "markly.table.alignCenter",
        "title": "Table: Align Center",
        "icon": "$(align-center)"
      },
      {
        "command": "markly.table.alignRight",
        "title": "Table: Align Right",
        "icon": "$(align-right)"
      },
      {
        "command": "markly.table.mergeCells",
        "title": "Table: Merge Cells",
        "icon": "$(combine)"
      },
      {
        "command": "markly.table.splitCell",
        "title": "Table: Split Cell",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "markly.table.deleteTable",
        "title": "Table: Delete Table",
        "icon": "$(trash)"
      },
      {
        "command": "markly.table.deleteRow",
        "title": "Table: Delete Row",
        "icon": "$(trash)"
      },
      {
        "command": "markly.table.deleteCol",
        "title": "Table: Delete Column",
        "icon": "$(trash)"
      },
      {
        "command": "markly.assist.summarize",
        "title": "Writing: Insert Local Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "markly.assist.suggestTitle",
        "title": "Writing: Suggest Title",
        "icon": "$(symbol-string)"
      },
      {
        "command": "markly.assist.fixMarkdown",
        "title": "Writing: Fix Markdown Spacing",
        "icon": "$(wand)"
      },
      {
        "command": "markly.assist.tidyTables",
        "title": "Writing: Tidy Markdown Tables",
        "icon": "$(table)"
      },
      {
        "command": "markly.assist.rewriteSelection",
        "title": "Writing: Rewrite Selection (local mock)",
        "icon": "$(edit)"
      },
      {
        "command": "markly.ai.setApiKey",
        "title": "AI: Set API Key",
        "icon": "$(key)"
      },
      {
        "command": "markly.ai.clearApiKey",
        "title": "AI: Clear API Key",
        "icon": "$(trash)"
      }
    ],
    "keybindings": [
      {
        "command": "markly.toggleMode",
        "key": "cmd+\\",
        "mac": "cmd+\\",
        "when": "editorLangId == markdown"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markly.toggleMode",
          "group": "navigation@1",
          "when": "editorLangId == markdown"
        },
        {
          "command": "markly.export.pdf",
          "group": "navigation@2",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "Markly",
      "properties": {
        "markly.image.saveDirectory": {
          "type": "string",
          "default": "./assets",
          "description": "Directory to save images (relative to document)"
        },
        "markly.image.compressThreshold": {
          "type": "number",
          "default": 512000,
          "description": "Image compression threshold in bytes (500KB default)"
        },
        "markly.image.compressQuality": {
          "type": "number",
          "default": 0.8,
          "description": "Image compression quality (0-1)"
        },
        "markly.editor.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "description": "Editor theme"
        },
        "markly.editor.fontSize": {
          "type": "number",
          "default": 14,
          "description": "Editor font size"
        },
        "markly.editor.fontFamily": {
          "type": "string",
          "default": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "description": "Editor font family"
        },
        "markly.editor.wrapPolicy": {
          "type": "string",
          "default": "autoWrap",
          "enum": [
            "autoWrap",
            "preferScroll"
          ],
          "description": "Overflow policy for long lines: auto wrap or prefer horizontal scroll"
        },
        "markly.editor.tableCellWrap": {
          "type": "string",
          "default": "wrap",
          "enum": [
            "wrap",
            "nowrap"
          ],
          "description": "Rich table cell wrapping: wrap text or keep single-line with horizontal scroll"
        },
        "markly.editor.enableMermaid": {
          "type": "boolean",
          "default": true,
          "description": "Enable Mermaid rendering in Rich mode (may impact performance)"
        },
        "markly.editor.enableShiki": {
          "type": "boolean",
          "default": false,
          "description": "Enable Shiki syntax highlighting in Rich mode (may impact stability)"
        },
        "markly.editor.defaultForMarkdown": {
          "type": "boolean",
          "default": true,
          "description": "Use Markly as the default editor for Markdown files"
        },
        "markly.export.pdf.format": {
          "type": "string",
          "default": "A4",
          "enum": [
            "A4",
            "A3",
            "Letter",
            "Legal"
          ],
          "description": "PDF page format"
        },
        "markly.export.pdf.margin": {
          "type": "object",
          "default": {
            "top": 25,
            "right": 20,
            "bottom": 25,
            "left": 20
          },
          "description": "PDF page margins in mm"
        },
        "markly.export.pdf.includeToc": {
          "type": "boolean",
          "default": true,
          "description": "Include table of contents in PDF export"
        },
        "markly.export.pdf.displayHeaderFooter": {
          "type": "boolean",
          "default": true,
          "description": "Display header/footer in PDF export"
        },
        "markly.export.html.theme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "print-friendly"
          ],
          "description": "HTML export theme: screen default vs print-oriented layout/CSS"
        },
        "markly.ai.rewrite.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Allow selection rewrite assist in the editor (uses local mock until a provider is configured)"
        },
        "markly.ai.rewrite.provider": {
          "type": "string",
          "default": "mock",
          "enum": [
            "none",
            "mock",
            "openai-compatible"
          ],
          "description": "Rewrite provider: none/mock/openai-compatible"
        },
        "markly.ai.rewrite.endpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "description": "openai-compatible endpoint URL"
        },
        "markly.ai.rewrite.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "openai-compatible model name"
        },
        "markly.ai.rewrite.timeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "description": "openai-compatible request timeout in milliseconds"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "markly.preview",
        "displayName": "Markly Preview",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --external:puppeteer --format=cjs --platform=node --minify --alias:@core=./src/core --alias:@types=./src/types --alias:@extension=./src/extension --alias:@editor=./src/editor --alias:@plugins=./src/plugins --alias:@image=./src/image --alias:@services=./src/services",
    "build:webview": "cd webview && npm run build",
    "check:bundle": "node ./scripts/check_webview_bundle.mjs && node ./scripts/check_extension_bundle.mjs",
    "check:bundle:webview": "node ./scripts/check_webview_bundle.mjs",
    "check:bundle:extension": "node ./scripts/check_extension_bundle.mjs",
    "check:release": "node ./scripts/check-release.mjs",
    "preflight": "npm run lint && npm test && npm run build && npm run check:bundle && npm run check:release",
    "gates:stable": "npm run lint && npm test && npm run build && npm run check:bundle",
    "m8:baseline": "node ./scripts/m8-baseline.mjs",
    "dev:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --format=cjs --platform=node --watch --alias:@core=./src/core --alias:@types=./src/types --alias:@extension=./src/extension --alias:@editor=./src/editor --alias:@plugins=./src/plugins --alias:@image=./src/image --alias:@services=./src/services",
    "dev:webview": "cd webview && npm run dev",
    "test": "vitest run && cd webview && npm test",
    "test:watch": "vitest",
    "test:vscode": "npm run build && node ./e2e/compile-suite-mocha-tests.mjs && node ./e2e/index.js",
    "test:vscode:ui:setup": "npx -y node@20.18.1 ./e2e/setup-extest-ui.mjs",
    "test:vscode:ui": "npm run build && npx -y node@20.18.1 ./e2e/run-extest-ui.mjs",
    "test:vscode:ui:stable": "MARKLY_UI_REPEAT=3 npm run test:vscode:ui",
    "vscode:ui": "npm run build && node ./e2e/vscode-ui-launch.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4",
    "vscode-extension-tester": "^8.23.0"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "katex": "^0.16.9",
    "marked": "^12.0.2",
    "mermaid": "^10.8.0",
    "puppeteer": "^24.38.0",
    "shiki": "^1.0.0",
    "tui-image-editor": "^3.15.3",
    "viewerjs": "^1.11.6"
  }
}
