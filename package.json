{
  "name": "markly",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "1.39.15",
  "publisher": "jianmo",
  "repository": {
    "type": "git",
    "url": "https://github.com/goodjin/jianmo.git"
  },
  "bugs": {
    "url": "https://github.com/goodjin/jianmo/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:markly.preview",
    "onLanguage:markdown",
    "onCommand:markly.template.newFromLibrary",
    "onWalkthrough:markly.welcome",
    "onCommand:markly.help.recoveryCenter"
  ],
  "main": "./dist/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "markly.toggleMode",
        "title": "%cmd.markly.toggleMode%",
        "icon": "$(refresh)",
        "category": "Markly"
      },
      {
        "command": "markly.export.pdf",
        "title": "%cmd.markly.export.pdf%",
        "icon": "$(file-pdf)",
        "category": "Markly"
      },
      {
        "command": "markly.export.html",
        "title": "%cmd.markly.export.html%",
        "icon": "$(file-code)",
        "category": "Markly"
      },
      {
        "command": "markly.export.copyFailureDiagnostics",
        "title": "%cmd.markly.export.copyFailureDiagnostics%",
        "icon": "$(copy)",
        "category": "Markly"
      },
      {
        "command": "markly.preview.exportHtml",
        "title": "%cmd.markly.preview.exportHtml%",
        "icon": "$(open-preview)",
        "category": "Markly"
      },
      {
        "command": "markly.template.newFromLibrary",
        "title": "%cmd.markly.template.newFromLibrary%",
        "icon": "$(file-add)",
        "category": "Markly"
      },
      {
        "command": "markly.export.image",
        "title": "%cmd.markly.export.image%",
        "icon": "$(file-media)",
        "category": "Markly"
      },
      {
        "command": "markly.toggleOutline",
        "title": "%cmd.markly.toggleOutline%",
        "icon": "$(list-tree)",
        "category": "Markly"
      },
      {
        "command": "markly.find.toggle",
        "title": "%cmd.markly.find.toggle%",
        "icon": "$(search)",
        "category": "Markly"
      },
      {
        "command": "markly.find.next",
        "title": "%cmd.markly.find.next%",
        "icon": "$(arrow-down)",
        "category": "Markly"
      },
      {
        "command": "markly.find.previous",
        "title": "%cmd.markly.find.previous%",
        "icon": "$(arrow-up)",
        "category": "Markly"
      },
      {
        "command": "markly.edit.pastePlain",
        "title": "%cmd.markly.edit.pastePlain%",
        "icon": "$(clippy)",
        "category": "Markly"
      },
      {
        "command": "markly.edit.wrapUrlLink",
        "title": "%cmd.markly.edit.wrapUrlLink%",
        "icon": "$(link-external)",
        "category": "Markly"
      },
      {
        "command": "markly.insert.table",
        "title": "%cmd.markly.insert.table%",
        "icon": "$(table)",
        "category": "Markly"
      },
      {
        "command": "markly.insert.codeBlock",
        "title": "%cmd.markly.insert.codeBlock%",
        "icon": "$(code)",
        "category": "Markly"
      },
      {
        "command": "markly.insert.image",
        "title": "%cmd.markly.insert.image%",
        "icon": "$(file-media)",
        "category": "Markly"
      },
      {
        "command": "markly.insert.link",
        "title": "%cmd.markly.insert.link%",
        "icon": "$(link)",
        "category": "Markly"
      },
      {
        "command": "markly.insert.hr",
        "title": "%cmd.markly.insert.hr%",
        "icon": "$(horizontal-rule)",
        "category": "Markly"
      },
      {
        "command": "markly.image.copyMissingRefs",
        "title": "%cmd.markly.image.copyMissingRefs%",
        "icon": "$(copy)",
        "category": "Markly"
      },
      {
        "command": "markly.image.copyUnreferencedList",
        "title": "%cmd.markly.image.copyUnreferencedList%",
        "icon": "$(file-media)",
        "category": "Markly"
      },
      {
        "command": "markly.image.openAssetsDirectory",
        "title": "%cmd.markly.image.openAssetsDirectory%",
        "icon": "$(folder-opened)",
        "category": "Markly"
      },
      {
        "command": "markly.image.openAssetsPanel",
        "title": "%cmd.markly.image.openAssetsPanel%",
        "icon": "$(references)",
        "category": "Markly"
      },
      {
        "command": "markly.image.repairFirstMissingRef",
        "title": "%cmd.markly.image.repairFirstMissingRef%",
        "icon": "$(wrench)",
        "category": "Markly"
      },
      {
        "command": "markly.image.repairMissingRefsBatch",
        "title": "%cmd.markly.image.repairMissingRefsBatch%",
        "icon": "$(wand)",
        "category": "Markly"
      },
      {
        "command": "markly.image.normalizeRefs",
        "title": "%cmd.markly.image.normalizeRefs%",
        "icon": "$(symbol-file)",
        "category": "Markly"
      },
      {
        "command": "markly.image.batchReplaceInDocument",
        "title": "%cmd.markly.image.batchReplaceInDocument%",
        "icon": "$(replace-all)",
        "category": "Markly"
      },
      {
        "command": "markly.image.replaceMovedImageRef",
        "title": "%cmd.markly.image.replaceMovedImageRef%",
        "icon": "$(files)",
        "category": "Markly"
      },
      {
        "command": "markly.table.addRowBefore",
        "title": "%cmd.markly.table.addRowBefore%",
        "icon": "$(insert)",
        "category": "Markly"
      },
      {
        "command": "markly.table.addRowAfter",
        "title": "%cmd.markly.table.addRowAfter%",
        "icon": "$(insert)",
        "category": "Markly"
      },
      {
        "command": "markly.table.addColBefore",
        "title": "%cmd.markly.table.addColBefore%",
        "icon": "$(insert)",
        "category": "Markly"
      },
      {
        "command": "markly.table.addColAfter",
        "title": "%cmd.markly.table.addColAfter%",
        "icon": "$(insert)",
        "category": "Markly"
      },
      {
        "command": "markly.table.toggleHeaderRow",
        "title": "%cmd.markly.table.toggleHeaderRow%",
        "icon": "$(table)",
        "category": "Markly"
      },
      {
        "command": "markly.table.alignLeft",
        "title": "%cmd.markly.table.alignLeft%",
        "icon": "$(align-left)",
        "category": "Markly"
      },
      {
        "command": "markly.table.alignCenter",
        "title": "%cmd.markly.table.alignCenter%",
        "icon": "$(align-center)",
        "category": "Markly"
      },
      {
        "command": "markly.table.alignRight",
        "title": "%cmd.markly.table.alignRight%",
        "icon": "$(align-right)",
        "category": "Markly"
      },
      {
        "command": "markly.table.mergeCells",
        "title": "%cmd.markly.table.mergeCells%",
        "icon": "$(combine)",
        "category": "Markly"
      },
      {
        "command": "markly.table.splitCell",
        "title": "%cmd.markly.table.splitCell%",
        "icon": "$(split-horizontal)",
        "category": "Markly"
      },
      {
        "command": "markly.table.deleteTable",
        "title": "%cmd.markly.table.deleteTable%",
        "icon": "$(trash)",
        "category": "Markly"
      },
      {
        "command": "markly.table.deleteRow",
        "title": "%cmd.markly.table.deleteRow%",
        "icon": "$(trash)",
        "category": "Markly"
      },
      {
        "command": "markly.table.deleteCol",
        "title": "%cmd.markly.table.deleteCol%",
        "icon": "$(trash)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.summarize",
        "title": "%cmd.markly.assist.summarize%",
        "icon": "$(sparkle)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.suggestTitle",
        "title": "%cmd.markly.assist.suggestTitle%",
        "icon": "$(symbol-string)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.fixMarkdown",
        "title": "%cmd.markly.assist.fixMarkdown%",
        "icon": "$(wand)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.tidyTables",
        "title": "%cmd.markly.assist.tidyTables%",
        "icon": "$(table)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.convertTextToGfmTable",
        "title": "%cmd.markly.assist.convertTextToGfmTable%",
        "icon": "$(table)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.rewriteSelection",
        "title": "%cmd.markly.assist.rewriteSelection%",
        "icon": "$(edit)",
        "category": "Markly"
      },
      {
        "command": "markly.ai.setApiKey",
        "title": "%cmd.markly.ai.setApiKey%",
        "icon": "$(key)",
        "category": "Markly"
      },
      {
        "command": "markly.ai.clearApiKey",
        "title": "%cmd.markly.ai.clearApiKey%",
        "icon": "$(trash)",
        "category": "Markly"
      },
      {
        "command": "markly.ai.validateSetup",
        "title": "%cmd.markly.ai.validateSetup%",
        "icon": "$(check)",
        "category": "Markly"
      },
      {
        "command": "markly.ai.openPrivacyNotice",
        "title": "%cmd.markly.ai.openPrivacyNotice%",
        "icon": "$(info)",
        "category": "Markly"
      },
      {
        "command": "markly.help.recoveryCenter",
        "title": "%cmd.markly.help.recoveryCenter%",
        "icon": "$(tools)",
        "category": "Markly"
      }
    ],
    "keybindings": [
      {
        "command": "markly.toggleMode",
        "key": "cmd+\\",
        "mac": "cmd+\\",
        "when": "editorLangId == markdown"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markly.toggleMode",
          "group": "navigation@1",
          "when": "editorLangId == markdown"
        },
        {
          "command": "markly.export.pdf",
          "group": "navigation@2",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "markly.welcome",
        "title": "%walkthrough.markly.welcome.title%",
        "description": "%walkthrough.markly.welcome.description%",
        "steps": [
          {
            "id": "markly.welcome.modes",
            "title": "%walkthrough.markly.welcome.step.modes.title%",
            "description": "%walkthrough.markly.welcome.step.modes.description%",
            "media": {
              "image": "images/icon.png",
              "altText": "%walkthrough.markly.welcome.step.modes.altText%"
            },
            "completionEvents": [
              "onStepSelected"
            ]
          },
          {
            "id": "markly.welcome.export",
            "title": "%walkthrough.markly.welcome.step.export.title%",
            "description": "%walkthrough.markly.welcome.step.export.description%",
            "media": {
              "image": "images/icon.png",
              "altText": "%walkthrough.markly.welcome.step.export.altText%"
            },
            "completionEvents": [
              "onStepSelected"
            ]
          },
          {
            "id": "markly.welcome.assets",
            "title": "%walkthrough.markly.welcome.step.assets.title%",
            "description": "%walkthrough.markly.welcome.step.assets.description%",
            "media": {
              "image": "images/icon.png",
              "altText": "%walkthrough.markly.welcome.step.assets.altText%"
            },
            "completionEvents": [
              "onStepSelected"
            ]
          },
          {
            "id": "markly.welcome.recovery",
            "title": "%walkthrough.markly.welcome.step.recovery.title%",
            "description": "%walkthrough.markly.welcome.step.recovery.description%",
            "media": {
              "image": "images/icon.png",
              "altText": "%walkthrough.markly.welcome.step.recovery.altText%"
            },
            "completionEvents": [
              "onCommand:markly.help.recoveryCenter"
            ]
          }
        ]
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "markly.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.markly.telemetry.enabled.markdownDescription%"
        },
        "markly.image.saveDirectory": {
          "type": "string",
          "default": "./assets",
          "description": "%config.markly.image.saveDirectory.description%",
          "markdownDescription": "%config.markly.image.saveDirectory.markdownDescription%"
        },
        "markly.image.compressThreshold": {
          "type": "number",
          "default": 512000,
          "description": "%config.markly.image.compressThreshold.description%"
        },
        "markly.image.compressQuality": {
          "type": "number",
          "default": 0.8,
          "description": "%config.markly.image.compressQuality.description%"
        },
        "markly.image.sameNameHandling": {
          "type": "string",
          "enum": [
            "overwrite",
            "rename",
            "prompt"
          ],
          "default": "rename",
          "description": "%config.markly.image.sameNameHandling.description%"
        },
        "markly.editor.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "description": "%config.markly.editor.theme.description%"
        },
        "markly.editor.fontSize": {
          "type": "number",
          "default": 14,
          "description": "%config.markly.editor.fontSize.description%"
        },
        "markly.editor.fontFamily": {
          "type": "string",
          "default": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "description": "%config.markly.editor.fontFamily.description%"
        },
        "markly.editor.wrapPolicy": {
          "type": "string",
          "default": "autoWrap",
          "enum": [
            "autoWrap",
            "preferScroll"
          ],
          "description": "%config.markly.editor.wrapPolicy.description%"
        },
        "markly.editor.tableCellWrap": {
          "type": "string",
          "default": "wrap",
          "enum": [
            "wrap",
            "nowrap"
          ],
          "description": "%config.markly.editor.tableCellWrap.description%"
        },
        "markly.editor.enableMermaid": {
          "type": "boolean",
          "default": true,
          "description": "%config.markly.editor.enableMermaid.description%",
          "markdownDescription": "%config.markly.editor.enableMermaid.markdownDescription%"
        },
        "markly.editor.enableShiki": {
          "type": "boolean",
          "default": false,
          "description": "%config.markly.editor.enableShiki.description%",
          "markdownDescription": "%config.markly.editor.enableShiki.markdownDescription%"
        },
        "markly.editor.richTableColumnResize": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "on",
            "off"
          ],
          "description": "%config.markly.editor.richTableColumnResize.description%"
        },
        "markly.editor.deferDiagramRenderInRich": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.markly.editor.deferDiagramRenderInRich.markdownDescription%"
        },
        "markly.editor.defaultForMarkdown": {
          "type": "boolean",
          "default": true,
          "description": "%config.markly.editor.defaultForMarkdown.description%"
        },
        "markly.export.pdf.format": {
          "type": "string",
          "default": "A4",
          "enum": [
            "A4",
            "A3",
            "Letter",
            "Legal"
          ],
          "description": "%config.markly.export.pdf.format.description%"
        },
        "markly.export.pdf.margin": {
          "type": "object",
          "default": {
            "top": 25,
            "right": 20,
            "bottom": 25,
            "left": 20
          },
          "description": "%config.markly.export.pdf.margin.description%"
        },
        "markly.export.pdf.includeToc": {
          "type": "boolean",
          "default": true,
          "description": "%config.markly.export.pdf.includeToc.description%"
        },
        "markly.export.pdf.displayHeaderFooter": {
          "type": "boolean",
          "default": true,
          "description": "%config.markly.export.pdf.displayHeaderFooter.description%"
        },
        "markly.export.pdf.template": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "academic"
          ],
          "description": "%config.markly.export.pdf.template.description%"
        },
        "markly.export.html.theme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "print-friendly"
          ],
          "description": "%config.markly.export.html.theme.description%"
        },
        "markly.export.html.copyLocalImages": {
          "type": "boolean",
          "default": false,
          "description": "%config.markly.export.html.copyLocalImages.description%"
        },
        "markly.export.html.assetsSubdirectory": {
          "type": "string",
          "default": "markly-html-assets",
          "description": "%config.markly.export.html.assetsSubdirectory.description%"
        },
        "markly.export.diagram.mermaidScriptBundling": {
          "type": "string",
          "default": "embedded",
          "enum": [
            "embedded",
            "external"
          ],
          "markdownDescription": "%config.markly.export.diagram.mermaidScriptBundling.markdownDescription%"
        },
        "markly.export.preflight.scope": {
          "type": "string",
          "default": "full",
          "enum": [
            "off",
            "images",
            "full"
          ],
          "description": "%config.markly.export.preflight.scope.description%",
          "markdownDescription": "%config.markly.export.preflight.scope.markdownDescription%"
        },
        "markly.export.preflight.blockOnIssues": {
          "type": "boolean",
          "default": false,
          "description": "%config.markly.export.preflight.blockOnIssues.description%",
          "markdownDescription": "%config.markly.export.preflight.blockOnIssues.markdownDescription%"
        },
        "markly.image.remoteHttpsHostsAllowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "%config.markly.image.remoteHttpsHostsAllowlist.markdownDescription%"
        },
        "markly.image.pasteImageBasenamePrefix": {
          "type": "string",
          "default": "paste",
          "markdownDescription": "%config.markly.image.pasteImageBasenamePrefix.markdownDescription%"
        },
        "markly.templates.userDirectory": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.markly.templates.userDirectory.markdownDescription%"
        },
        "markly.ai.rewrite.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.markly.ai.rewrite.enabled.description%",
          "markdownDescription": "%config.markly.ai.rewrite.enabled.markdownDescription%"
        },
        "markly.ai.rewrite.provider": {
          "type": "string",
          "default": "mock",
          "enum": [
            "none",
            "mock",
            "openai-compatible"
          ],
          "description": "%config.markly.ai.rewrite.provider.description%",
          "markdownDescription": "%config.markly.ai.rewrite.provider.markdownDescription%"
        },
        "markly.ai.rewrite.endpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "description": "%config.markly.ai.rewrite.endpoint.description%"
        },
        "markly.ai.rewrite.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "%config.markly.ai.rewrite.model.description%"
        },
        "markly.ai.rewrite.timeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "description": "%config.markly.ai.rewrite.timeoutMs.description%"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "markly.preview",
        "displayName": "Markly Preview",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --external:puppeteer --format=cjs --platform=node --minify --alias:@core=./src/core --alias:@types=./src/types --alias:@extension=./src/extension --alias:@editor=./src/editor --alias:@plugins=./src/plugins --alias:@image=./src/image --alias:@services=./src/services",
    "build:webview": "cd webview && npm run build",
    "check:ir-freeze": "node ./scripts/check-ir-freeze.mjs",
    "check:bundle": "node ./scripts/check_webview_bundle.mjs && node ./scripts/check_extension_bundle.mjs",
    "check:bundle:webview": "node ./scripts/check_webview_bundle.mjs",
    "check:bundle:extension": "node ./scripts/check_extension_bundle.mjs",
    "check:release": "node ./scripts/check-release.mjs",
    "preflight": "npm run lint && npm run check:ir-freeze && npm test && npm run build && npm run check:bundle && npm run check:release",
    "gates:stable": "npm run lint && npm run check:ir-freeze && npm test && npm run build && npm run check:bundle",
    "m8:baseline": "node ./scripts/m8-baseline.mjs",
    "sbom:generate": "node ./scripts/generate-sbom.mjs",
    "dev:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --format=cjs --platform=node --watch --alias:@core=./src/core --alias:@types=./src/types --alias:@extension=./src/extension --alias:@editor=./src/editor --alias:@plugins=./src/plugins --alias:@image=./src/image --alias:@services=./src/services",
    "dev:webview": "cd webview && npm run dev",
    "test": "vitest run && cd webview && npm test",
    "test:watch": "vitest",
    "test:vscode": "npm run build && node ./e2e/compile-suite-mocha-tests.mjs && node ./e2e/index.js",
    "record:bundle-sizes": "node ./scripts/record-bundle-sizes.mjs",
    "test:vscode:ui:setup": "npx -y node@20.18.1 ./e2e/setup-extest-ui.mjs",
    "test:vscode:ui": "npm run build && npx -y node@20.18.1 ./e2e/run-extest-ui.mjs",
    "test:vscode:ui:stable": "MARKLY_UI_REPEAT=3 npm run test:vscode:ui",
    "vscode:ui": "npm run build && node ./e2e/vscode-ui-launch.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "images:optimize": "node ./scripts/optimize-images.mjs",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "oxipng-bin": "^1.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4",
