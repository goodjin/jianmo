{
  "name": "markly",
  "displayName": "Markly",
  "description": "A clean and intuitive WYSIWYG Markdown editor for VSCode",
  "version": "1.39.15",
  "publisher": "jianmo",
  "repository": {
    "type": "git",
    "url": "https://github.com/goodjin/jianmo.git"
  },
  "bugs": {
    "url": "https://github.com/goodjin/jianmo/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:markly.preview",
    "onLanguage:markdown",
    "onCommand:markly.template.newFromLibrary",
    "onWalkthrough:markly.welcome",
    "onCommand:markly.help.recoveryCenter"
  ],
  "main": "./dist/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "markly.toggleMode",
        "title": "Toggle Edit Mode (切换 Rich / Source)",
        "icon": "$(refresh)",
        "category": "Markly"
      },
      {
        "command": "markly.export.pdf",
        "title": "Export as PDF (导出 PDF)",
        "icon": "$(file-pdf)",
        "category": "Markly"
      },
      {
        "command": "markly.export.html",
        "title": "Export as HTML (导出 HTML)",
        "icon": "$(file-code)",
        "category": "Markly"
      },
      {
        "command": "markly.export.copyFailureDiagnostics",
        "title": "Export: Copy Last Failure Diagnostics",
        "icon": "$(copy)",
        "category": "Markly"
      },
      {
        "command": "markly.preview.exportHtml",
        "title": "Preview: Export HTML (read-only)",
        "icon": "$(open-preview)",
        "category": "Markly"
      },
      {
        "command": "markly.template.newFromLibrary",
        "title": "New Markdown from Template…",
        "icon": "$(file-add)",
        "category": "Markly"
      },
      {
        "command": "markly.export.image",
        "title": "Export as Image",
