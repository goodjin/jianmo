        "icon": "$(insert)",
        "category": "Markly"
      },
      {
        "command": "markly.table.addColBefore",
        "title": "Table: Add Column Left",
        "icon": "$(insert)",
        "category": "Markly"
      },
      {
        "command": "markly.table.addColAfter",
        "title": "Table: Add Column Right",
        "icon": "$(insert)",
        "category": "Markly"
      },
      {
        "command": "markly.table.toggleHeaderRow",
        "title": "Table: Toggle Header Row",
        "icon": "$(table)",
        "category": "Markly"
      },
      {
        "command": "markly.table.alignLeft",
        "title": "Table: Align Left",
        "icon": "$(align-left)",
        "category": "Markly"
      },
      {
        "command": "markly.table.alignCenter",
        "title": "Table: Align Center",
        "icon": "$(align-center)",
        "category": "Markly"
      },
      {
        "command": "markly.table.alignRight",
        "title": "Table: Align Right",
        "icon": "$(align-right)",
        "category": "Markly"
      },
      {
        "command": "markly.table.mergeCells",
        "title": "Table: Merge Cells",
        "icon": "$(combine)",
        "category": "Markly"
      },
      {
        "command": "markly.table.splitCell",
        "title": "Table: Split Cell",
        "icon": "$(split-horizontal)",
        "category": "Markly"
      },
      {
        "command": "markly.table.deleteTable",
        "title": "Table: Delete Table",
