{
  "name": "jianmo-markdown",
  "displayName": "简墨",
  "description": "简洁轻量，智能好用 - 为用户体验而生的 Markdown 编辑器",
  "version": "0.1.0",
  "publisher": "jianmo",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:md-editor.preview",
    "onLanguage:markdown"
  ],
  "main": "./dist/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "mdEditor.toggleMode",
        "title": "Toggle Edit Mode",
        "icon": "$(refresh)"
      },
      {
        "command": "mdEditor.export.pdf",
        "title": "Export as PDF",
        "icon": "$(file-pdf)"
      },
      {
        "command": "mdEditor.export.html",
        "title": "Export as HTML",
        "icon": "$(file-code)"
      },
      {
        "command": "mdEditor.export.image",
        "title": "Export as Image",
        "icon": "$(file-media)"
      }
    ],
    "keybindings": [
      {
        "command": "mdEditor.toggleMode",
        "key": "cmd+\\",
        "mac": "cmd+\\",
        "when": "editorLangId == markdown"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mdEditor.toggleMode",
          "group": "navigation@1",
          "when": "editorLangId == markdown"
        },
        {
          "command": "mdEditor.export.pdf",
          "group": "navigation@2",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Editor",
      "properties": {
        "mdEditor.image.saveDirectory": {
          "type": "string",
          "default": "./assets",
          "description": "Directory to save images (relative to document)"
        },
        "mdEditor.image.compressThreshold": {
          "type": "number",
          "default": 512000,
          "description": "Image compression threshold in bytes (500KB default)"
        },
        "mdEditor.image.compressQuality": {
          "type": "number",
          "default": 0.8,
          "description": "Image compression quality (0-1)"
        },
        "mdEditor.editor.theme": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "light", "dark"],
          "description": "Editor theme"
        },
        "mdEditor.editor.fontSize": {
          "type": "number",
          "default": 14,
          "description": "Editor font size"
        },
        "mdEditor.editor.fontFamily": {
          "type": "string",
          "default": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "description": "Editor font family"
        },
        "mdEditor.export.pdf.format": {
          "type": "string",
          "default": "A4",
          "enum": ["A4", "A3", "Letter", "Legal"],
          "description": "PDF page format"
        },
        "mdEditor.export.pdf.margin": {
          "type": "object",
          "default": {
            "top": 25,
            "right": 20,
            "bottom": 25,
            "left": 20
          },
          "description": "PDF page margins in mm"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "md-editor.preview",
        "displayName": "Markdown Editor Preview",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --format=cjs --platform=node --minify",
    "build:webview": "cd webview && npm run build",
    "dev:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --format=cjs --platform=node --watch",
    "dev:webview": "cd webview && npm run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "@milkdown/core": "^7.3.6",
    "@milkdown/preset-commonmark": "^7.3.6",
    "@milkdown/preset-gfm": "^7.3.6",
    "@milkdown/plugin-listener": "^7.3.6",
    "@milkdown/plugin-history": "^7.3.6",
    "@milkdown/plugin-math": "^7.3.6",
    "@milkdown/vue": "^7.3.6",
    "katex": "^0.16.9",
    "marked": "^12.0.0",
    "mermaid": "^10.8.0",
    "shiki": "^1.0.0",
    "viewerjs": "^1.11.6",
    "tui-image-editor": "^3.15.3",
    "browser-image-compression": "^2.0.2"
  }
}
