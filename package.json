        "category": "Markly"
      },
      {
        "command": "markly.ai.openPrivacyNotice",
        "title": "AI: Open Privacy Notice",
        "icon": "$(info)",
        "category": "Markly"
      },
      {
        "command": "markly.help.recoveryCenter",
        "title": "Help: Open Recovery & Troubleshooting",
        "icon": "$(tools)",
        "category": "Markly"
      }
    ],
    "keybindings": [
      {
        "command": "markly.toggleMode",
        "key": "cmd+\\",
        "mac": "cmd+\\",
        "when": "editorLangId == markdown"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markly.toggleMode",
          "group": "navigation@1",
          "when": "editorLangId == markdown"
        },
        {
          "command": "markly.export.pdf",
          "group": "navigation@2",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "markly.welcome",
        "title": "Markly 快速上手",
        "description": "熟悉 Rich / Source、导出与快捷键；遇到问题可查自救指南。",
        "steps": [
          {
            "id": "markly.welcome.modes",
            "title": "Rich 与 Source",
            "description": "**推荐主路径**：工具栏切换 **Rich**（所见即所得）与 **Source**（Markdown 源码）。命令面板：**Markly: Toggle Edit Mode (切换 Rich / Source)**（默认快捷键 macOS `Cmd+\\`，Windows / Linux `Ctrl+\\`）。\n\n历史 **IR（中间模式）** 已冻结、不向新场景投入；如需了解迁移与移除计划见仓库 **`docs/IR_REMOVAL_ROADMAP.md`**。\n\n[打开键盘快捷方式](command:workbench.action.openGlobalKeybindings)",
            "media": {
              "image": "images/icon.png",
              "altText": "Markly"
            },
            "completionEvents": ["onStepSelected"]
          },
          {
            "id": "markly.welcome.export",
            "title": "导出 PDF / HTML",
            "description": "编辑器标题栏可快速导出；或在命令面板搜索 **Export as PDF** / **Export as HTML**。导出失败时可复制诊断包（**Export: Copy Last Failure Diagnostics**）。",
            "media": {
              "image": "images/icon.png",
              "altText": "Export"
            },
            "completionEvents": ["onStepSelected"]
          },
          {
            "id": "markly.welcome.assets",
            "title": "图片与资产",
            "description": "粘贴图片默认写入文档相对目录（见设置 **markly.image.saveDirectory**）。缺失图、未引用资产可用命令面板里的 **Images:** 系列命令修复。\n\n[打开设置（搜索 markly）](command:workbench.action.openSettings)",
            "media": {
              "image": "images/icon.png",
              "altText": "Assets"
            },
            "completionEvents": ["onStepSelected"]
          },
          {
            "id": "markly.welcome.recovery",
            "title": "遇到问题？自救中心",
            "description": "集中查看 Rich / 导出 / 资产的常见问题与命令入口。\n\n[打开自救与排障指南](command:markly.help.recoveryCenter)",
            "media": {
              "image": "images/icon.png",
              "altText": "Recovery"
            },
            "completionEvents": ["onCommand:markly.help.recoveryCenter"]
          }
        ]
      }
    ],
    "configuration": {
      "title": "Markly",
      "properties": {
        "markly.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**可选匿名遥测（默认关闭）。**\n\n- `false`（默认）：不向第三方发送遥测；不在本地 Output 记录计数。\n- `true`：仅在本地 **Output → 「Markly Telemetry (local)」** 写入匿名事件计数（如会话开始、导出成功），便于你自己排查；**仍不向第三方发送**。后续若接入云端需另行隐私说明与同意。\n\n示例：保持默认即可：`\"markly.telemetry.enabled\": false`"
        },
        "markly.image.saveDirectory": {
          "type": "string",
          "default": "./assets",
          "description": "Subdirectory for pasted/dropped images, relative to the Markdown file.",
          "markdownDescription": "粘贴/拖入图片时，相对 **当前 Markdown 文件** 保存的子目录。\n\n示例： `\"./assets\"` → 图片落在 `文档同级/assets/`；`\"./images\"` → `文档同级/images/`。"
        },
        "markly.image.compressThreshold": {
          "type": "number",
          "default": 512000,
          "description": "Image compression threshold in bytes (500KB default)"
        },
        "markly.image.compressQuality": {
          "type": "number",
          "default": 0.8,
          "description": "Image compression quality (0-1)"
        },
        "markly.image.sameNameHandling": {
          "type": "string",
          "enum": [
            "overwrite",
            "rename",
            "prompt"
          ],
          "default": "rename",
          "description": "When saving a pasted/dropped image, if an asset filename already exists: overwrite file, pick a unique name automatically, or ask (prompt)"
        },
        "markly.editor.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "description": "Editor theme"
        },
        "markly.editor.fontSize": {
          "type": "number",
          "default": 14,
          "description": "Editor font size"
        },
        "markly.editor.fontFamily": {
          "type": "string",
          "default": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "description": "Editor font family"
        },
        "markly.editor.wrapPolicy": {
          "type": "string",
          "default": "autoWrap",
          "enum": [
            "autoWrap",
            "preferScroll"
          ],
          "description": "Overflow policy for long lines: auto wrap or prefer horizontal scroll"
        },
        "markly.editor.tableCellWrap": {
          "type": "string",
          "default": "wrap",
          "enum": [
            "wrap",
            "nowrap"
          ],
          "description": "Rich table cell wrapping: wrap text or keep single-line with horizontal scroll"
        },
        "markly.editor.enableMermaid": {
          "type": "boolean",
          "default": true,
          "description": "Enable Mermaid rendering in Rich mode (may impact performance)",
          "markdownDescription": "Rich 模式下是否渲染 Mermaid 图（导出 HTML/PDF 时也会内联处理）。\n\n- **示例**：`true`（默认）在文档较大或图多时可能更耗 CPU；卡顿可先改为 `false` 再试。\n- 与 **包体/依赖**：`mermaid` 为扩展依赖，详见仓库 `resources/BUNDLE_GOVERNANCE.md`。"
        },
        "markly.editor.enableShiki": {
          "type": "boolean",
          "default": false,
          "description": "Enable Shiki syntax highlighting in Rich mode (may impact stability)",
          "markdownDescription": "Rich 模式下代码块是否用 Shiki 高亮。\n\n- **示例**：默认 `false`（更稳）；开启后大文档可能与 **档位** 降级联动。\n- Shiki 与主题字体一并影响编辑负载。"
        },
        "markly.editor.richTableColumnResize": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "on",
            "off"
          ],
          "description": "Rich mode: draggable column widths in tables. Auto skips the plugin for large tables (same soft limits as table paste) to reduce scroll/selection latency; use on/off to force."
        },
        "markly.editor.deferDiagramRenderInRich": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "为 `true` 时 Rich 模式 **完全不初始化 Mermaid**，图表保持 ```mermaid 源码块形态（省电/弱机可先开）；与文档体量档位/看门狗降级正交。**导出 HTML/PDF 不受影响**。\n\n- 性能档位与启动说明：**`resources/PERFORMANCE_NOTES.md`**\n- **IR（decorator 中间模式）冻结**、不向新用户推荐使用：**`docs/IR_REMOVAL_ROADMAP.md`**；近期收口路线：**`docs/ROADMAP_NEAR.md`**（M201+）"
        },
        "markly.editor.defaultForMarkdown": {
          "type": "boolean",
          "default": true,
          "description": "Use Markly as the default editor for Markdown files"
        },
        "markly.export.pdf.format": {
          "type": "string",
          "default": "A4",
          "enum": [
            "A4",
            "A3",
            "Letter",
            "Legal"
          ],
          "description": "PDF page format"
        },
        "markly.export.pdf.margin": {
          "type": "object",
          "default": {
            "top": 25,
            "right": 20,
            "bottom": 25,
            "left": 20
          },
          "description": "PDF page margins in mm"
        },
        "markly.export.pdf.includeToc": {
          "type": "boolean",
          "default": true,
          "description": "Include table of contents in PDF export"
        },
        "markly.export.pdf.displayHeaderFooter": {
          "type": "boolean",
          "default": true,
          "description": "Display header/footer in PDF export"
        },
        "markly.export.pdf.template": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "academic"
          ],
          "description": "PDF layout theme: default (GitHub-like sans) vs academic (serif, print-oriented colors). Page margins still use export.pdf.margin."
        },
        "markly.export.html.theme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "print-friendly"
          ],
          "description": "HTML export theme: screen default vs print-oriented layout/CSS"
        },
        "markly.export.html.copyLocalImages": {
          "type": "boolean",
          "default": false,
          "description": "M82: When exporting HTML, copy local images (relative to the Markdown file directory) next to the output file and rewrite <img src>."
        },
        "markly.export.html.assetsSubdirectory": {
          "type": "string",
          "default": "markly-html-assets",
          "description": "M82: Subfolder name under the HTML output directory for copied images. Must be a single segment (no /, \\, or ..)."
        },
        "markly.export.diagram.mermaidScriptBundling": {
          "type": "string",
          "default": "embedded",
          "enum": [
            "embedded",
            "external"
          ],
          "markdownDescription": "**M40**：导出 HTML/PDF/预览里的 Mermaid 脚本注入方式。\n\n- **embedded（默认）**：内联扩展自带的 `mermaid.min.js`，离线可渲染，文件较大。\n- **external**：从 jsDelivr 拉取与扩展固定版本一致的 `mermaid.min.js`，HTML 体积小，导出环境需联网。"
        },
        "markly.export.preflight.scope": {
          "type": "string",
          "default": "full",
          "enum": [
            "off",
            "images",
            "full"
          ],
          "description": "M83: Preflight before PDF/HTML export. off: none; images: missing local images only; full: images + missing local markdown links + unbalanced $/$$ math delimiters (heuristic).",
          "markdownDescription": "导出 PDF/HTML **之前** 的静态检查范围。\n\n| 值 | 含义 |\n|----|------|\n| `off` | 不检查 |\n| `images` | 仅缺失本地图片 |\n| `full`（默认） | 图片 + 失效本地 Markdown 链接 + `$`/`$$` 数学定界符启发式检查 |\n\n**示例**：若只想快导出、接受缺图，可设 `\"markly.export.preflight.scope\": \"off\"`。"
        },
        "markly.export.preflight.blockOnIssues": {
          "type": "boolean",
          "default": false,
          "description": "M83: When true, if preflight finds any issue, show a modal and require confirmation before exporting.",
          "markdownDescription": "为 `true` 时，预检发现问题会 **弹窗确认** 后才继续导出；`false` 时仅展示问题（若实现为通知）或仍允许一键继续。适合「不想带着错图就发 PDF」的工作流。"
        },
        "markly.image.remoteHttpsHostsAllowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "**M46**：HTTPS 外链图片 **host** 允许列表。\n\n- **空数组（默认）**：不额外告警。\n- **非空**：在导出预检「images/full」范围内，对每个 `![](https://…)` 检查 host（忽略大小写、`www.` 前缀）是否列出；不符合则报错/提示。**http://** 同样检查。"
        },
        "markly.image.pasteImageBasenamePrefix": {
          "type": "string",
          "default": "paste",
          "markdownDescription": "**M49**：粘贴/保存到工作区的图片文件名前缀：`{前缀}-YYYYMMDD-HHmmss-{随机}.{扩展}`。\n\n仅影响 **新生成** 的文件名。"
        },
        "markly.templates.userDirectory": {
          "type": "string",
          "default": "",
          "markdownDescription": "M90: Folder containing your own `*.md` / `*.markdown` templates (top level only). Use an absolute path or `~/…` for under the user home directory. Empty: only built-in templates appear in **New Markdown from Template**."
        },
        "markly.ai.rewrite.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Allow AI writing assists (selection rewrite, sidecar summary, title suggest, table conversion, etc.).",
          "markdownDescription": "开启后，侧栏摘要、标题建议、选区润色、选区转表等 **AI 能力** 才会按配置访问提供商。\n\n- **默认 `false`**：不向任何 Endpoint 发起 AI 请求（相当于「默认不上传全文 / 不做后台同步」）。\n- 使用 **openai-compatible** 时，出站 HTTPS **仅在你点击对应功能的那一次**发生，且传输范围见随扩展附带的说明文档。\n\n命令：**AI: Open Privacy Notice**（`markly.ai.openPrivacyNotice`）。"
        },
        "markly.ai.rewrite.provider": {
          "type": "string",
          "default": "mock",
          "enum": [
            "none",
            "mock",
            "openai-compatible"
          ],
          "description": "AI provider: none / mock (no remote HTTP) / openai-compatible.",
          "markdownDescription": "- **`mock`（默认）** / **`none`**：不向公网发送写作内容（`none` 下相关能力会按实现拒绝）。\n- **`openai-compatible`**：仅在 `markly.ai.rewrite.enabled=true` 且你执行具体 AI 操作时，将对应文本片段发往 `markly.ai.rewrite.endpoint`。\n\n完整数据范围与「三句话可复述」摘要：**AI: Open Privacy Notice**。"
        },
        "markly.ai.rewrite.endpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "description": "openai-compatible endpoint URL (usually ends with /v1/chat/completions). Tip: run “AI: Validate Setup” after changing settings."
        },
        "markly.ai.rewrite.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "openai-compatible model name. Tip: run “AI: Set API Key” once (stored in VS Code SecretStorage)."
        },
        "markly.ai.rewrite.timeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "description": "openai-compatible request timeout in milliseconds"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "markly.preview",
        "displayName": "Markly Preview",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --external:puppeteer --format=cjs --platform=node --minify --alias:@core=./src/core --alias:@types=./src/types --alias:@extension=./src/extension --alias:@editor=./src/editor --alias:@plugins=./src/plugins --alias:@image=./src/image --alias:@services=./src/services",
    "build:webview": "cd webview && npm run build",
    "check:ir-freeze": "node ./scripts/check-ir-freeze.mjs",
    "check:bundle": "node ./scripts/check_webview_bundle.mjs && node ./scripts/check_extension_bundle.mjs",
    "check:bundle:webview": "node ./scripts/check_webview_bundle.mjs",
    "check:bundle:extension": "node ./scripts/check_extension_bundle.mjs",
    "check:release": "node ./scripts/check-release.mjs",
    "preflight": "npm run lint && npm run check:ir-freeze && npm test && npm run build && npm run check:bundle && npm run check:release",
    "gates:stable": "npm run lint && npm run check:ir-freeze && npm test && npm run build && npm run check:bundle",
    "m8:baseline": "node ./scripts/m8-baseline.mjs",
    "dev:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --format=cjs --platform=node --watch --alias:@core=./src/core --alias:@types=./src/types --alias:@extension=./src/extension --alias:@editor=./src/editor --alias:@plugins=./src/plugins --alias:@image=./src/image --alias:@services=./src/services",
    "dev:webview": "cd webview && npm run dev",
    "test": "vitest run && cd webview && npm test",
    "test:watch": "vitest",
    "test:vscode": "npm run build && node ./e2e/compile-suite-mocha-tests.mjs && node ./e2e/index.js",
    "record:bundle-sizes": "node ./scripts/record-bundle-sizes.mjs",
    "test:vscode:ui:setup": "npx -y node@20.18.1 ./e2e/setup-extest-ui.mjs",
    "test:vscode:ui": "npm run build && npx -y node@20.18.1 ./e2e/run-extest-ui.mjs",
    "test:vscode:ui:stable": "MARKLY_UI_REPEAT=3 npm run test:vscode:ui",
    "vscode:ui": "npm run build && node ./e2e/vscode-ui-launch.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4",
    "vscode-extension-tester": "^8.23.0"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "katex": "^0.16.9",
    "marked": "^12.0.2",
    "mermaid": "^11.12.3",
    "puppeteer": "^24.38.0",
    "shiki": "^1.0.0",
    "tui-image-editor": "^3.15.3",
    "viewerjs": "^1.11.6"
  }
}
