{
  "name": "markly",
  "displayName": "Markly",
  "description": "A clean and intuitive WYSIWYG Markdown editor for VSCode",
  "version": "0.1.0",
  "publisher": "jianmo",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:markly.preview",
    "onLanguage:markdown"
  ],
  "main": "./dist/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "markly.toggleMode",
        "title": "Toggle Edit Mode",
        "icon": "$(refresh)"
      },
      {
        "command": "markly.export.pdf",
        "title": "Export as PDF",
        "icon": "$(file-pdf)"
      },
      {
        "command": "markly.export.html",
        "title": "Export as HTML",
        "icon": "$(file-code)"
      },
      {
        "command": "markly.export.image",
        "title": "Export as Image",
        "icon": "$(file-media)"
      }
    ],
    "keybindings": [
      {
        "command": "markly.toggleMode",
        "key": "cmd+\\",
        "mac": "cmd+\\",
        "when": "editorLangId == markdown"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markly.toggleMode",
          "group": "navigation@1",
          "when": "editorLangId == markdown"
        },
        {
          "command": "markly.export.pdf",
          "group": "navigation@2",
          "when": "editorLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "Markly",
      "properties": {
        "markly.image.saveDirectory": {
          "type": "string",
          "default": "./assets",
          "description": "Directory to save images (relative to document)"
        },
        "markly.image.compressThreshold": {
          "type": "number",
          "default": 512000,
          "description": "Image compression threshold in bytes (500KB default)"
        },
        "markly.image.compressQuality": {
          "type": "number",
          "default": 0.8,
          "description": "Image compression quality (0-1)"
        },
        "markly.editor.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "description": "Editor theme"
        },
        "markly.editor.fontSize": {
          "type": "number",
          "default": 14,
          "description": "Editor font size"
        },
        "markly.editor.fontFamily": {
          "type": "string",
          "default": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "description": "Editor font family"
        },
        "markly.editor.defaultForMarkdown": {
          "type": "boolean",
          "default": true,
          "description": "Use Markly as the default editor for Markdown files"
        },
        "markly.export.pdf.format": {
          "type": "string",
          "default": "A4",
          "enum": [
            "A4",
            "A3",
            "Letter",
            "Legal"
          ],
          "description": "PDF page format"
        },
        "markly.export.pdf.margin": {
          "type": "object",
          "default": {
            "top": 25,
            "right": 20,
            "bottom": 25,
            "left": 20
          },
          "description": "PDF page margins in mm"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "markly.preview",
        "displayName": "Markly Preview",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --format=cjs --platform=node --minify",
    "build:webview": "cd webview && npm run build",
    "dev:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --format=cjs --platform=node --watch",
    "dev:webview": "cd webview && npm run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:vscode": "node node_modules/@vscode/test-electron/out/cli.js",
    "lint": "eslint src --ext .ts,.tsx",
    "package": "vsce package"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "playwright": "^1.58.2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  },
  "dependencies": {
    "@milkdown/core": "^7.3.6",
    "@milkdown/plugin-history": "^7.3.6",
    "@milkdown/plugin-listener": "^7.3.6",
    "@milkdown/plugin-math": "^7.3.6",
    "@milkdown/plugin-table": "^5.3.1",
    "@milkdown/preset-commonmark": "^7.3.6",
    "@milkdown/preset-gfm": "^7.19.0",
    "@milkdown/utils": "^7.19.0",
    "@milkdown/vue": "^7.3.6",
    "browser-image-compression": "^2.0.2",
    "katex": "^0.16.9",
    "marked": "^12.0.2",
    "mermaid": "^10.8.0",
    "puppeteer": "^24.38.0",
    "remark-footnotes": "^4.0.1",
    "shiki": "^1.0.0",
    "tui-image-editor": "^3.15.3",
    "viewerjs": "^1.11.6"
  }
}
