        "icon": "$(trash)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.summarize",
        "title": "Writing: Insert Local Summary",
        "icon": "$(sparkle)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.suggestTitle",
        "title": "Writing: Suggest Title",
        "icon": "$(symbol-string)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.fixMarkdown",
        "title": "Writing: Fix Markdown Structure",
        "icon": "$(wand)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.tidyTables",
        "title": "Writing: Tidy Markdown Tables",
        "icon": "$(table)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.convertTextToGfmTable",
        "title": "Writing: Convert Selection to GFM Table (AI)",
        "icon": "$(table)",
        "category": "Markly"
      },
      {
        "command": "markly.assist.rewriteSelection",
        "title": "Writing: Rewrite Selection (local mock)",
        "icon": "$(edit)",
        "category": "Markly"
      },
      {
